{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/certificate/layout,_N_T_/(app)/certificate/page,_N_T_/certificate"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/certificate/__PAGE__",
    "/!KGFwcCk/certificate",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}