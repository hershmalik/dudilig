{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/analyze/layout,_N_T_/(app)/analyze/page,_N_T_/analyze"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/analyze/__PAGE__",
    "/!KGFwcCk/analyze",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}