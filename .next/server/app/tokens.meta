{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/tokens/layout,_N_T_/(app)/tokens/page,_N_T_/tokens"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/tokens/__PAGE__",
    "/!KGFwcCk/tokens",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}