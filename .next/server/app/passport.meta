{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/passport/layout,_N_T_/(app)/passport/page,_N_T_/passport"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/passport/__PAGE__",
    "/!KGFwcCk/passport",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}